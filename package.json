{
  "name": "codextheme",
  "version": "0.1.0",
  "private": true,
  "description": "One-command themes for Codex Desktop.",
  "type": "module",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "themes:build": "node themes/scripts/generate-art.mjs && node themes/scripts/pack.mjs",
    "site:build": "npm run build -w @codextheme/site",
    "build": "npm run themes:build && npm run site:build",
    "check": "npm run typecheck && npm test && npm run build && node scripts/check-packages.mjs"
  },
  "engines": {
    "node": ">=22.4"
  },
  "devDependencies": {
    "sharp": "0.35.3"
  }
}
