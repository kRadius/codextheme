{
  "schemaVersion": 1,
  "id": "cathedral-nocturne",
  "displayName": "Cathedral Nocturne / 黑金圣堂",
  "version": "1.1.0",
  "images": {
    "hero": "assets/hero.jpg",
    "session-bg": "assets/session.jpg",
    "icon-new-chat": "assets/icons/icon-new-chat.png",
    "icon-pull-requests": "assets/icons/icon-pull-requests.png",
    "icon-scheduled": "assets/icons/icon-scheduled.png",
    "icon-plugins": "assets/icons/icon-plugins.png",
    "icon-project-folder": "assets/icons/icon-project-folder.png",
    "icon-explore": "assets/icons/icon-explore.png",
    "icon-build": "assets/icons/icon-build.png",
    "icon-review": "assets/icons/icon-review.png",
    "icon-fix": "assets/icons/icon-fix.png",
    "icon-add": "assets/icons/icon-add.png",
    "icon-send": "assets/icons/icon-send.png"
  },
  "copy": {
    "brandTitle": "CATHEDRAL NOCTURNE",
    "brandSubtitle": "codextheme.tech",
    "signature": "01 / SACRED GOLD",
    "tagline": "Build in a quieter, grander world.",
    "projectPrefix": "NAVE / ",
    "projectLabel": "Select a project",
    "ribbon": "◆"
  },
  "targets": {
    "codex": {
      "css": "../shared/codex.css",
      "options": {
        "rendererProfile": "codex-theme-v1",
        "baseTheme": {
          "mode": "dark",
          "codeTheme": "codex",
          "accent": "#c7a45a",
          "contrast": 74,
          "ink": "#f3eee3",
          "surface": "#15120e",
          "opaqueWindows": true,
          "semanticColors": {
            "diffAdded": "#79c79c",
            "diffRemoved": "#df6b72",
            "skill": "#d5b96f"
          }
        }
      },
      "verification": {
        "recommended": [
          { "name": "session-surface", "any": ["main.main-surface"] },
          { "name": "composer-surface", "any": [".composer-surface-chrome"] },
          { "name": "icon-new-chat", "any": ["aside.app-shell-left-panel [role='navigation'] .vertical-scroll-fade-mask > div:first-child > div > div > div > button:nth-child(1) svg"] },
          { "name": "icon-pull-requests", "any": ["aside.app-shell-left-panel [role='navigation'] .vertical-scroll-fade-mask > div:first-child > div > div > div > button:nth-child(2) svg"] },
          { "name": "icon-scheduled", "any": ["aside.app-shell-left-panel [role='navigation'] .vertical-scroll-fade-mask > div:first-child > div > div > div > button:nth-child(3) svg"] },
          { "name": "icon-plugins", "any": ["aside.app-shell-left-panel [role='navigation'] .vertical-scroll-fade-mask > div:first-child > div > div > div > button:nth-child(4) svg"] },
          { "name": "icon-project-folder", "any": ["aside.app-shell-left-panel .group\\/folder-row > div:first-child > span:first-child > svg"] },
          { "name": "icon-add", "any": [".composer-surface-chrome .col-start-1 button.aspect-square > svg"] },
          { "name": "icon-send", "any": [".composer-surface-chrome button.size-token-button-composer > svg"] }
        ],
        "contexts": [
          {
            "name": "home",
            "when": { "any": [".dream-home"] },
            "recommended": [
              { "name": "icon-explore", "any": [".dream-home .group\\/home-suggestions button:nth-child(1) svg"] },
              { "name": "icon-build", "any": [".dream-home .group\\/home-suggestions button:nth-child(2) svg"] },
              { "name": "icon-review", "any": [".dream-home .group\\/home-suggestions button:nth-child(3) svg"] },
              { "name": "icon-fix", "any": [".dream-home .group\\/home-suggestions button:nth-child(4) svg"] }
            ]
          }
        ]
      }
    }
  }
}
