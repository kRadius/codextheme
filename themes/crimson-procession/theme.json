{
  "schemaVersion": 1,
  "id": "crimson-procession",
  "displayName": "Crimson Procession / 赤月回廊",
  "version": "1.0.0",
  "images": {
    "hero": "assets/hero.jpg",
    "session-bg": "assets/session.jpg"
  },
  "copy": {
    "brandTitle": "CRIMSON PROCESSION",
    "brandSubtitle": "codextheme.tech",
    "signature": "02 / CRIMSON MOON",
    "tagline": "Keep the mission in sight.",
    "projectPrefix": "CLOISTER / ",
    "projectLabel": "Select a project",
    "ribbon": "◆"
  },
  "targets": {
    "codex": {
      "css": "../shared/codex.css",
      "options": {
        "rendererProfile": "codex-theme-v1",
        "baseTheme": {
          "mode": "dark",
          "codeTheme": "codex",
          "accent": "#d34a55",
          "contrast": 74,
          "ink": "#f4e9e9",
          "surface": "#160c0e",
          "opaqueWindows": true,
          "semanticColors": {
            "diffAdded": "#75c99a",
            "diffRemoved": "#ef5969",
            "skill": "#e17a7f"
          }
        }
      },
      "verification": {
        "recommended": [
          { "name": "session-surface", "any": ["main.main-surface"] },
          { "name": "composer-surface", "any": [".composer-surface-chrome"] }
        ]
      }
    }
  }
}
